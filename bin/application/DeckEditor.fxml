<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="application.DeckEditorController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="top-bar">
            <Label styleClass="title-label" text="Edit Deck" />
        </HBox>
    </top>
    <center>
        <VBox spacing="6" VBox.vgrow="ALWAYS" style="-fx-padding: 12 16 0 16;">
            <!-- Deck Name and Owner Row -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="deckNameField" promptText="Deck Name" styleClass="text-field" HBox.hgrow="ALWAYS" minWidth="200" />
                <Label fx:id="ownerLabel" text="Owner: -" minWidth="100" />
                <CheckBox fx:id="publicCheckBox" text="Share this deck (public)" minWidth="180" />
            </HBox>
            
            <!-- Table takes all vertical space -->
            <TableView fx:id="cardsTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="frontColumn" text="Front" minWidth="120" />
                    <TableColumn fx:id="backColumn" text="Back" minWidth="120" />
                    <TableColumn fx:id="pictureColumn" text="Picture" minWidth="80" maxWidth="100" resizable="false" />
                </columns>
            </TableView>
        </VBox>
    </center>
    <bottom>
        <VBox spacing="0" VBox.vgrow="NEVER">
            <!-- Input fields row -->
            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 6 16 4 16; -fx-background-color: transparent;">
                <TextField fx:id="frontInput" promptText="Front" styleClass="text-field" HBox.hgrow="ALWAYS" minWidth="100" />
                <TextField fx:id="backInput" promptText="Back" styleClass="text-field" HBox.hgrow="ALWAYS" minWidth="100" />
                <Button fx:id="attachImageButton" styleClass="secondary-button" text="Attach Image" minWidth="100" />
                <Button fx:id="addCardButton" styleClass="primary-button" text="Add Card" minWidth="80" />
                <Button fx:id="deleteCardButton" styleClass="danger-button" text="Delete" minWidth="70" />
            </HBox>
            
            <!-- Image preview row -->
            <HBox alignment="CENTER_LEFT" spacing="10" minHeight="40" style="-fx-padding: 0 16 2 16;">
                <ImageView fx:id="imagePreview" fitWidth="60" fitHeight="40" preserveRatio="true" />
            </HBox>
            
            <!-- Return button bar -->
            <HBox alignment="CENTER_RIGHT" styleClass="bottom-bar" style="-fx-padding: 6 16;">
                <Button fx:id="returnButton" styleClass="warning-button" text="Return to Dashboard" minWidth="150" />
            </HBox>
        </VBox>
    </bottom>
</BorderPane>